# Example environment variables for local development and production
# Copy this to .env (do NOT check your real .env into source control)

# Django settings
DJANGO_SECRET_KEY=replace_me_with_a_strong_secret_key
DJANGO_DEBUG=True
# Comma-separated hosts, e.g. example.com,api.example.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS
# Comma-separated origins allowed to call the API (include scheme)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# Database (MySQL)
MYSQL_NAME=lolc_agreement
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# JWT / Session
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Production security toggles (set to true in production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_PROXY_SSL_HEADER=False

# Frontend
# Base URL the frontend should use to call the API (optional override)
# Backend base URL used by scripts and optionally by the frontend.
# NOTE: `API_BASE` is required for Python scripts (export API_BASE="http://127.0.0.1:8000").
# For the frontend (CRA) you can set `REACT_APP_API_BASE` to override the dev proxy
# or leave it empty to use relative paths / the CRA `proxy` setting.
REACT_APP_API_BASE=

# Example (development):
# API_BASE=http://127.0.0.1:8000
# REACT_APP_API_BASE=http://127.0.0.1:8000

# Additional optional flags
# SECURE_BROWSER_XSS_FILTER, SECURE_CONTENT_TYPE_NOSNIFF and X_FRAME_OPTIONS
# are configured in settings.py; set `X_FRAME_OPTIONS=DENY` to override.
MYSQL_NAME=lolc_operasional
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
